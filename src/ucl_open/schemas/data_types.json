{
  "$defs": {
    "DataTypes": {
      "properties": {
        "vector3": {
          "$ref": "#/$defs/Vector3"
        },
        "softwareEvent": {
          "$ref": "#/$defs/SoftwareEvent"
        },
        "spoutRigPosition": {
          "$ref": "#/$defs/SpoutRigPosition"
        }
      },
      "required": [
        "vector3",
        "softwareEvent",
        "spoutRigPosition"
      ],
      "title": "DataTypes",
      "type": "object"
    },
    "DisplayCalibration": {
      "properties": {
        "intrinsics": {
          "$ref": "#/$defs/DisplayIntrinsics",
          "default": {
            "frameWidth": 1920,
            "frameHeight": 1080,
            "displayWidth": 20.0,
            "displayHeight": 15.0
          },
          "description": "Intrinsics",
          "title": "Intrinsics"
        },
        "extrinsics": {
          "$ref": "#/$defs/DisplayExtrinsics",
          "default": {
            "rotation": {
              "x": 0.0,
              "y": 0.0,
              "z": 0.0
            },
            "translation": {
              "x": 0.0,
              "y": 1.309016,
              "z": -13.27
            }
          },
          "description": "Extrinsics",
          "title": "Extrinsics"
        }
      },
      "title": "DisplayCalibration",
      "type": "object"
    },
    "DisplayExtrinsics": {
      "properties": {
        "rotation": {
          "$ref": "#/$defs/Vector3",
          "default": {
            "x": 0.0,
            "y": 0.0,
            "z": 0.0
          },
          "description": "Rotation vector (radians)",
          "title": "Rotation"
        },
        "translation": {
          "$ref": "#/$defs/Vector3",
          "default": {
            "x": 0.0,
            "y": 1.309016,
            "z": -13.27
          },
          "description": "Translation (in cm)",
          "title": "Translation"
        }
      },
      "title": "DisplayExtrinsics",
      "type": "object"
    },
    "DisplayIntrinsics": {
      "properties": {
        "frameWidth": {
          "default": 1920,
          "description": "Frame width (px)",
          "minimum": 0,
          "title": "FrameWidth",
          "type": "integer"
        },
        "frameHeight": {
          "default": 1080,
          "description": "Frame height (px)",
          "minimum": 0,
          "title": "FrameHeight",
          "type": "integer"
        },
        "displayWidth": {
          "default": 20,
          "description": "Display width (cm)",
          "minimum": 0,
          "title": "DisplayWidth",
          "type": "number"
        },
        "displayHeight": {
          "default": 15,
          "description": "Display width (cm)",
          "minimum": 0,
          "title": "DisplayHeight",
          "type": "number"
        }
      },
      "title": "DisplayIntrinsics",
      "type": "object"
    },
    "Displays": {
      "properties": {
        "displayCalibration": {
          "$ref": "#/$defs/DisplayCalibration"
        }
      },
      "required": [
        "displayCalibration"
      ],
      "title": "Displays",
      "type": "object"
    },
    "SoftwareEvent": {
      "description": "A software event is a generic event that can be used to track any event that occurs in the software.",
      "properties": {
        "name": {
          "description": "The name of the event.",
          "title": "Name",
          "type": "string"
        },
        "timestamp": {
          "default": null,
          "description": "The timestamp of the event.",
          "title": "Timestamp",
          "type": [
            "number",
            "null"
          ]
        },
        "timestampSource": {
          "$ref": "#/$defs/TimestampSource",
          "default": "null",
          "description": "The source of the timestamp. Typically either a harp device or on the visual render loop"
        },
        "frameIndex": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The frame index of the event.",
          "title": "FrameIndex"
        },
        "frameTimestamp": {
          "default": null,
          "description": "The timestamp of the frame.",
          "title": "FrameTimestamp",
          "type": [
            "number",
            "null"
          ]
        },
        "data": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The data payload of the event.",
          "title": "Data"
        }
      },
      "required": [
        "name"
      ],
      "title": "SoftwareEvent",
      "type": "object"
    },
    "SpoutRigPosition": {
      "description": "Dictionary of named absolute positions, e.g.:\n  home, both_in, both_out",
      "properties": {
        "positions": {
          "additionalProperties": {
            "$ref": "#/$defs/StepperPositions"
          },
          "description": "Named absolute positions of the lick spout stage stepper rig, keyed by a string identifier.",
          "examples": [
            {
              "both_in": {
                "base_transverse": 500,
                "left_elevation": 1000,
                "left_radial": 2000,
                "right_elevation": 1000,
                "right_radial": 2000
              },
              "both_out": {
                "base_transverse": 500,
                "left_elevation": 1000,
                "left_radial": 1000,
                "right_elevation": 1000,
                "right_radial": 1000
              },
              "home": {
                "base_transverse": 0,
                "left_elevation": 0,
                "left_radial": 0,
                "right_elevation": 0,
                "right_radial": 0
              }
            }
          ],
          "title": "Positions",
          "type": "object"
        }
      },
      "title": "SpoutRigPosition",
      "type": "object"
    },
    "StepperPositions": {
      "description": "Absolute target position for the 5-axis spout rig, expressed in task-relative axes.",
      "properties": {
        "leftElevation": {
          "description": "Left spout elevation axis absolute position (steps). Maps to motor 1",
          "title": "LeftElevation",
          "type": "integer"
        },
        "rightElevation": {
          "description": "Right spout elevation axis absolute position (steps). Maps to motor 2",
          "title": "RightElevation",
          "type": "integer"
        },
        "rightRadial": {
          "description": "Right spout radial axis (in/out) absolute position (steps). Maps to motor 3",
          "title": "RightRadial",
          "type": "integer"
        },
        "leftRadial": {
          "description": "Left spout radial axis (in/out) absolute position (steps). Maps to motor 4",
          "title": "LeftRadial",
          "type": "integer"
        },
        "baseTransverse": {
          "description": "Base transverse axis absolute position (steps). Maps to motor 5",
          "title": "BaseTransverse",
          "type": "integer"
        }
      },
      "required": [
        "leftElevation",
        "rightElevation",
        "rightRadial",
        "leftRadial",
        "baseTransverse"
      ],
      "title": "StepperPositions",
      "type": "object"
    },
    "TimestampSource": {
      "enum": [
        "null",
        "harp",
        "render",
        "arduino"
      ],
      "title": "TimestampSource",
      "type": "string"
    },
    "Vector3": {
      "properties": {
        "x": {
          "description": "X coordinate of the point.",
          "title": "X",
          "type": "number"
        },
        "y": {
          "description": "Y coordinate of the point.",
          "title": "Y",
          "type": "number"
        },
        "z": {
          "description": "Z coordinate of the point.",
          "title": "Z",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "title": "Vector3",
      "type": "object"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/DataTypes"
    },
    {
      "$ref": "#/$defs/Displays"
    }
  ],
  "title": "RootModel[Union[DataTypes, Displays]]"
}